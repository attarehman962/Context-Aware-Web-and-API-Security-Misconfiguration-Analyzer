cat > /home/salahudin/Desktop/cawasma/.env.example << 'EOF'
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

FLASK_SECRET_KEY=change-this-to-any-random-string
FLASK_DEBUG=True
DATABASE_URL=sqlite:///cawasma.db
REDIS_URL=redis://localhost:6379/0
SCAN_TIMEOUT=30
MAX_CRAWL_DEPTH=2
MAX_ENDPOINTS=100
RATE_LIMIT_BURST=20
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=your-key-here
NLP_MODEL_NAME=all-MiniLM-L6-v2
EOF

cat > /home/salahudin/Desktop/cawasma/.gitignore << 'EOF'
__pycache__/
*.py[cod]
venv/
env/
.venv/
.env
*.db
*.sqlite
instance/
.cache/
*.pdf
.pytest_cache/
.coverage
celerybeat-schedule
*.log
.DS_Store
EOF

echo ".env.example + .gitignore done"